{
  "name": "Quantum Dev Environment",
  "image": "mcr.microsoft.com/devcontainers/python:3.14",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12",
      "installTools": false
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter"
      ],
      "settings": {
        // Default to the `qiskit` venv inside the hidden `.venvs` folder
        "python.defaultInterpreterPath": "${workspaceFolder}/.venvs/qiskit/bin/python",
        "jupyter.notebookFileRoot": "${workspaceFolder}"
      },
      "terminal.integrated.env.linux": {
        "PATH": "${workspaceFolder}/.venvs/qiskit/bin:${env:PATH}"
      }
    }
  },
  // Create the hidden venvs folder and any venvs after the container spins up
  "postCreateCommand": "bash setup_venvs.sh"
}